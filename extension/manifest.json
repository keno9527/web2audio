{
  "manifest_version": 3,
  "name": "web2audio",
  "version": "0.1.0",
  "description": "Submit the current article to web2audio.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["http://127.0.0.1:8000/*", "http://localhost:8000/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "web2audio"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
